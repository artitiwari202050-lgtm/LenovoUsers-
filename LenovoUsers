<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GadgetHub Demo Store</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#f5f5f5;
}

header{
background:#1d2733;
padding:15px 40px;
display:flex;
justify-content:space-between;
align-items:center;
color:white;
position:sticky;
top:0;
}

.logo{
font-size:30px;
font-weight:bold;
}

.search{
width:45%;
padding:12px;
border-radius:8px;
border:none;
font-size:16px;
}

.cart{
background:#ff9800;
padding:10px 18px;
border-radius:8px;
color:white;
font-weight:bold;
}

.notice{
background:#fff3cd;
padding:15px;
text-align:center;
font-weight:bold;
}

.container{
max-width:1200px;
margin:auto;
padding:40px 20px;
}

.product{
display:flex;
flex-wrap:wrap;
background:white;
border-radius:15px;
box-shadow:0 8px 20px rgba(0,0,0,.12);
overflow:hidden;
}

.image{
flex:1;
min-width:300px;
padding:40px;
text-align:center;
}

.image img{
width:100%;
max-width:420px;
border-radius:10px;
}

.details{
flex:1;
padding:40px;
}

.details h1{
font-size:36px;
margin-bottom:15px;
}

.rating{
color:#ff9800;
font-size:22px;
margin-bottom:15px;
}

.old{
color:gray;
text-decoration:line-through;
font-size:22px;
}

.price{
font-size:48px;
color:#B12704;
font-weight:bold;
margin:15px 0;
}

.stock{
display:inline-block;
background:#d32f2f;
color:white;
padding:12px 25px;
border-radius:30px;
font-size:18px;
margin-bottom:25px;
}

button{
padding:15px 35px;
font-size:18px;
background:#9e9e9e;
color:white;
border:none;
border-radius:10px;
cursor:not-allowed;
}

.features{
margin-top:25px;
line-height:2;
font-size:18px;
}

.related{
margin-top:60px;
}

.cards{
display:flex;
gap:20px;
flex-wrap:wrap;
}

.card{
background:white;
padding:20px;
border-radius:12px;
flex:1;
min-width:220px;
text-align:center;
box-shadow:0 4px 12px rgba(0,0,0,.1);
}

.card img{
width:100%;
border-radius:10px;
}

.card h3{
margin:10px 0;
}

footer{
margin-top:60px;
background:#1d2733;
color:white;
text-align:center;
padding:25px;
}
</style>
</head>

<body>

<header>

<div class="logo">🎮 GadgetHub</div>

<input class="search" placeholder="Search for gadgets...">

<div class="cart">
🛒 Cart (0)
</div>

</header>

<div class="notice">
⚠ DEMO WEBSITE — No real purchases can be made.
</div>

<div class="container">

<div class="product">

<div class="image">

<img src="https://placehold.co/600x600/ffffff/000000?text=White+Controller">

</div>

<div class="details">

<h1>White EvoFox V1 S2 Wireless Controller</h1>

<div class="rating">
★★★★★ 4.8 (1,240 Reviews)
</div>

<div class="old">
₹2,499
</div>

<div class="price">
₹0
</div>

<div class="stock">
Currently Out of Stock
</div>

<br>

<button disabled>
Out of Stock
</button>

<div class="features">

✔ Premium Ergonomic Design<br>

✔ Wireless Connectivity<br>

✔ Vibration Feedback<br>

✔ USB-C Charging<br>

✔ Windows & Android Compatible

</div>

</div>

</div>

<div class="related">

<h2>Related Products</h2>

<br>

<div class="cards">

<div class="card">
<img src="https://placehold.co/250x250?text=Gaming+Mouse">
<h3>Gaming Mouse</h3>
₹999
</div>

<div class="card">
<img src="https://placehold.co/250x250?text=RGB+Keyboard">
<h3>RGB Keyboard</h3>
₹1,499
</div>

<div class="card">
<img src="https://placehold.co/250x250?text=Gaming+Headset">
<h3>Gaming Headset</h3>
₹1,999
</div>

</div>

</div>

</div>

<footer>

© 2026 GadgetHub Demo Store

</footer>

<script>

console.log("GadgetHub Loaded");

document.querySelector(".search").addEventListener("keyup",function(){

console.log("Searching:",this.value);

});

</script>

</body>
</html>
